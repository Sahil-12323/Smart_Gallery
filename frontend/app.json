{
  "expo": {
    "name": "AI Gallery",
    "slug": "ai-gallery",
    "owner": "sahil6383",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ai-gallery",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aigallery.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AI Gallery needs access to your photos.",
        "NSCameraUsageDescription": "AI Gallery needs camera access."
      }
    },
    "android": {
      "package": "com.aigallery.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "AI Gallery needs access to analyze and upload your photos."
        }
      ],
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
